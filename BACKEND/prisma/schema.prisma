generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id String @id @default(uuid())

  name  String?
  email String  @unique

  phone    String?
  password String?

  profileImage String?

  role Role @default(USER)

  headline String?
  bio      String? @db.Text

  location String?
  address  String? @db.Text

  isVerified Boolean @default(false)
  isBlocked  Boolean @default(false)

  plan       Plan         @default(FREE)
  provider   AuthProvider @default(CREDENTIALS)
  providerId String?

  lastLoginAt  DateTime?
  lastActiveAt DateTime?

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  urls           Url[]
  resetPasswords ResetPassword[]
  tags           Tags[]
  categories     Category[]
  refreshTokens  RefreshToken[]
  @@unique([provider, providerId])
}

enum Plan {
  FREE
  PRO
}

enum Role {
  USER
  ADMIN
}

enum AuthProvider {
  CREDENTIALS
  GOOGLE
  GITHUB
}

model Url {
  id             String      @id @default(uuid())
  originalUrl    String
  normalizedUrl  String
  urlHash        String
  shortCode      String      @unique
  clicks         Int         @default(0)
  tempId         String?
  expirationDate DateTime?
  password       String?
  QrCode         String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  liveTime       DateTime?
  singleUse      Boolean     @default(false)
  used           Boolean     @default(false)
  userId         String?
  lastVisitedAt  DateTime?
  isActive       Boolean?    @default(true)
  isDeleted      Boolean     @default(false)
  deletedAt      DateTime?
  user           User?       @relation(fields: [userId], references: [id])
  urlRecords     UrlRecord[]
  categoryId     String?
  category       Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags           Tags[]

  @@index([tempId])
  @@index([shortCode])
  @@index([originalUrl])
}

model UrlRecord {
  id        String   @id @default(uuid())
  urlId     String
  url       Url      @relation(fields: [urlId], references: [id])
  browser   String?
  os        String?
  device    String?
  country   String?
  city      String?
  referrer  String?
  ipHash    String?
  visitedAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([urlId])
  @@index([urlId, visitedAt])
}

model ResetPassword {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Tags {
  id        String   @id @default(uuid())
  name      String
  color     String?  @default("#dc5334")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  urls      Url[]
  createdAt DateTime @default(now())

  @@unique([userId, name])
}

model Category {
  id        String   @id @default(uuid())
  name      String
  color     String?  @default("#6366F1")
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  urls      Url[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  revokedAt DateTime?
}
